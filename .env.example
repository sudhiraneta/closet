# Closet environment variables
# Copy to .env for local dev. For Render, set these in the dashboard
# under each service's Environment tab.

# ─── Required ────────────────────────────────────────────────────────

# Gemini API key — for vision analysis + outfit image generation
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Postgres connection string
# - Local:  postgresql://<user>@localhost:5433/ai_twin
# - Render: auto-wired from closet-db service (do NOT set manually on Render)
DATABASE_URL=postgresql://sudhirabadugu@localhost:5433/ai_twin

# ─── Frontend (closet-frontend service) ──────────────────────────────

# Backend API URL used by Next.js for /api/* rewrites
# - Local:  http://localhost:8001
# - Render: auto-wired from closet-api service (do NOT set manually on Render)
API_URL=http://localhost:8001

# ─── Optional ────────────────────────────────────────────────────────

# Embedding model for semantic search (must match pgvector dim=384)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Local folder to scan for new wardrobe photos
WARDROBE_INBOX=~/Downloads/wardrobe_inbox
